{
  "name": "@sansys/dss-mcp",
  "version": "1.0.0",
  "description": "MCP server for Design System Sansys — Read-Only Foundation (Phase 1)",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "build": "tsup src/index.ts src/http-server.ts --format esm --out-dir build",
    "dev": "tsup src/index.ts src/http-server.ts --format esm --out-dir build --watch",
    "start": "node build/index.js",
    "start:http": "node build/http-server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
